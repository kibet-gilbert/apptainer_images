Bootstrap: docker
From: ubuntu:24.04

%labels
    Author Gilbert Kibet
    Version 6.0.0
    Description czid-cli - Command line upload interface

%post
    apt update && \
    apt install -y --no-install-recommends \
        ca-certificates gzip curl wget gawk coreutils \
        && apt clean && rm -rf /var/lib/apt/lists/*
   wget -O /tmp/czid-cli_linux_amd64.deb https://github.com/chanzuckerberg/czid-cli/releases/latest/download/czid-cli_linux_amd64.deb
   dpkg -i /tmp/czid-cli_linux_amd64.deb || apt -f install -y
   rm /tmp/czid-cli_linux_amd64.deb

%help
    This container has czid-cli - Command line tool to upload data to czid web  
    It is designed to be used with Nextflow or standalone via:
        apptainer exec czid_cli.sif czid metagenomics upload-samples \
                                    -p 'Project Name' \
                                    --sequencing-platform Illumina \
                                    --metadata-csv your_metadata.csv \
                                    -m 'Metadata Name=Metadata Value' \
                                    your_directory_of_samples'

# %runscript
#     echo "This image is intended to be used as part of a pipeline."
#     echo "Use 'apptainer exec' with your own commands."
