BootStrap: docker
From: mambaorg/micromamba:1.5.10-noble

%files
    conda.yaml /scratch/conda.yml
    gfaTools_v0.9.0-beta.tar.gz /scratch/gfaTools_v0.9.0-beta.tar.gz

%post
    micromamba shell init -s bash -p /opt/conda  # ensure mamba works
    micromamba install -y -n base conda-forge::procps-ng conda-forge::libiconv=1.17 conda-forge::libidn2=2.3.2
    micromamba install -y -n base -f /scratch/conda.yml
    micromamba env export -n base --explicit > environment.lock
    echo ">> CONDA_LOCK_START"
    cat environment.lock
    echo "<< CONDA_LOCK_END"
    micromamba clean -a -y
    export PATH="$MAMBA_ROOT_PREFIX/bin:$PATH"

    # clone mgs2amr repo into /opt/mgs2amr
    git clone https://github.com/pieterjanvc/mgs2amr.git /opt/mgs2amr
    # make scripts executable
    chmod +x /opt/mgs2amr/*.sh
    # create /opt/mgs2amr/tools/ and link metacherchant.sh to it
    mkdir -p /opt/mgs2amr/tools
    ln -s /opt/conda/bin/metacherchant.sh /opt/mgs2amr/tools/metacherchant.sh

    # Install gfaTools R package from tarball
    R CMD INSTALL /scratch/gfaTools_v0.9.0-beta.tar.gz

%environment
    export PATH="$MAMBA_ROOT_PREFIX/bin:$PATH"
    export PATH="/opt/conda/bin:$PATH"
    export PATH="/opt/mgs2amr:$PATH"
    export CONDA_PREFIX="/opt/conda"
    export _JAVA_OPTIONS="-XX:CompressedClassSpaceSize=256m -XX:MaxMetaspaceSize=512m -Xss1m"
    # any other env vars your workflow needs...

%test
    echo "Verifying dependencies in PATH..."
    # 'command -v' or 'which' will exit with an error if the tool is not found
    command -v sqlite3
    command -v Rscript
    command -v blastn
    command -v usearch
    command -v gfatools
    command -v metacherchant.sh
    command -v mgs2amr.sh
    command -v seqtk
    which usearch blastn gfatools metacherchant.sh python
    # bash /opt/mgs2amr/setup.sh -t
    
    # Test R package availability specifically
    Rscript -e "library(tidyverse)"
    Rscript -e "library(gfaTools); packageVersion('gfaTools')"

#%runscript
#    echo "Run with '--app' option (run 'apptainer run-help' for available apps)"

%apprun mgs2amr.sh
    /opt/mgs2amr/mgs2amr.sh $*

%apprun localBlast.sh
    /opt/mgs2amr/localBlast.sh $*

%apprun annotation.sh
    /opt/mgs2amr/annotation.sh $*

%apprun setup.sh
    /opt/mgs2amr/setup.sh $*

%apprun metacherchant.sh
    /opt/mgs2amr/tools/metacherchant.sh $*

%help
    Apptainer container for mgs2amr
    Apps available:
    * mgs2amr.sh
    * localBlast.sh
    * annotation.sh
    * setup.sh
    * R
    * blastn
    * metacherchant.sh
    * usearch
    * sqlite3
    * pigz
    * gfatools
    * seqtk

%labels
    author="Gilbert Kibet"
    author_email="gilykibe@gmail.com"

