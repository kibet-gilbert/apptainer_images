Bootstrap: docker
From: ubuntu:22.04

%labels
    Author Gilbert Kibet
    Version 1.0
    Description Convert gzipped FASTQ to FASTA using awk and gunzip

%post
    apt-get update && \
    apt-get install -y --no-install-recommends \
        gzip \
        gawk \
        coreutils \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

%help
    This container converts FASTQ.gz files to FASTA format using AWK and gunzip.
    It is designed to be used with Nextflow or standalone via:
        apptainer exec fastq_to_fasta.sif bash -c 'gunzip -c input.fastq.gz | awk ...'

%runscript
    echo "This image is intended to be used as part of a pipeline."
    echo "Use 'apptainer exec' with your own commands."
