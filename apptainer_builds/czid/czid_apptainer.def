Bootstrap: docker
From: ubuntu:22.04

%files
    # Copy local workflow files if needed
    # ./workflows /opt/workflows

%environment
    # Set environment variables
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PATH=/opt/conda/bin:$PATH
    export PATH=/opt/conda/envs/czid/bin:$PATH
    export CONDA_PREFIX=/opt/conda
    export CONDA_ENVS_PATH=/opt/conda/envs
    export PYTHONPATH=/opt/workflows:$PYTHONPATH
    
    # Tool-specific paths
    export BOWTIE2_BUILD=/opt/conda/bin/bowtie2-build
    export SAMTOOLS=/opt/conda/bin/samtools

%post
    # Update and install system dependencies
    apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y \
        build-essential \
        wget \
        curl \
        git \
        ca-certificates \
        procps \
        file \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        libncurses5-dev \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libgsl-dev \
        libgomp1 \
        openjdk-11-jre-headless \
        perl \
        python3 \
        python3-pip \
        python3-dev \
        r-base \
        # Bioinformatics tools often needed
        bowtie2 \
        samtools \
        bcftools \
        bedtools \
        && rm -rf /var/lib/apt/lists/*

    # Install Miniconda
    wget https://repo.anaconda.com/miniconda/Miniconda3-py39_4.12.0-Linux-x86_64.sh -O /tmp/miniconda.sh
    bash /tmp/miniconda.sh -b -p /opt/conda
    rm /tmp/miniconda.sh

    # Initialize conda
    /opt/conda/bin/conda init bash
    /opt/conda/bin/conda config --add channels conda-forge
    /opt/conda/bin/conda config --add channels bioconda
    /opt/conda/bin/conda config --set channel_priority strict

    # Create and activate conda environment
    . /opt/conda/etc/profile.d/conda.sh
    conda create -n czid python=3.9 -y
    conda activate czid

    # Install Python packages from requirements.txt (if exists)
    # pip install -r /opt/workflows/requirements.txt

    # Install bioinformatics tools via conda
    conda install -c bioconda -y \
        bowtie2=2.4.5 \
        samtools=1.16.1 \
        bcftools=1.16 \
        bedtools=2.30.0 \
        kraken2=2.1.2 \
        minimap2=2.24 \
        megahit=1.2.9 \
        spades=3.15.5 \
        trimmomatic=0.39 \
        fastp=0.23.2 \
        blast=2.13.0 \
        diamond=2.0.15 \
        seqtk=1.3 \
        fastqc=0.11.9 \
        multiqc=1.14 \
        r-essentials \
        r-tidyverse \
        r-data.table \
        # Add other tools from the Dockerfile

    # Install Python packages
    pip install \
        numpy==1.23.5 \
        pandas==1.5.3 \
        pysam==0.21.0 \
        biopython==1.81 \
        scikit-learn==1.2.2 \
        matplotlib==3.7.1 \
        seaborn==0.12.2 \
        jupyter==1.0.0 \
        # Add other Python packages

    # Clean conda cache
    conda clean -a -y

    # Clone or copy workflow code
    cd /opt
    git clone https://github.com/chanzuckerberg/czid-workflows.git
    mv czid-workflows/workflows/short-read-mngs /opt/workflows
    rm -rf czid-workflows

    # Make directories for data
    mkdir -p /data/inputs /data/outputs /data/references

    # Set permissions
    chmod -R a+rX /opt/conda
    chmod -R a+rX /opt/workflows

%runscript
    # Default: run the main workflow script
    exec python /opt/workflows/run.py "$@"

%startscript
    # Commands to run when container starts
    echo "Starting CZID workflow container"

%test
    # Test commands to verify installation
    conda --version
    python --version
    bowtie2 --version
    samtools --version
    which python

%labels
    Author CZID Team
    Version v1.0.0
    Description "Chan Zuckerberg ID short-read metagenomics workflow"
    License MIT
    Source https://github.com/chanzuckerberg/czid-workflows

%help
    This container runs the CZID short-read metagenomics workflow.
    
    To run the workflow:
        apptainer run czid-workflow.sif --input /data/inputs --output /data/outputs
    
    To get a shell in the container:
        apptainer shell czid-workflow.sif
