Bootstrap: docker
From: continuumio/miniconda3

%files
    seqDataQC.yaml

%post
    #git clone https://github.com/artic-network/fieldbioinformatics
    #cd fieldbioinformatics && python setup.py install
    #conda install mamba
    /opt/conda/bin/conda env create -f seqDataQC.yaml
    NOW=`date`
    dataQCversion="seqDataQC_sif.V`date +"%Y.%m.%d"`"
    echo "export NOW=\"${NOW}\"" >> ${APPTAINER_ENVIRONMENT}
    #rm -rf /opt/conda/envs/magviral/opt/krona/taxonomy

%environment
    export PATH=/opt/conda/bin:$PATH
    export PATH=/opt/conda/envs/seqdataqc/bin:$PATH
    export $dataQCversion

%runscript
    echo "Created on $NOW"
    exec $*

%test
    bcl_to_fastq -h
    bcl2fastq -v
    fastp -v
    fastqc -v
    kraken2 -v
    ktImportTaxonomy
    bowtie2
    samtools
    usearch

%labels
    Author: kibet-gilbert
    Version: $dataQCversion

%help
    Singularity container for viral shotgun metagenomics - MAGviral
    Apps available:
    bcl_to_fastq	Converts bcl to fastq file format and demultiplex
    bcl2fastq		Demultiplexes and converts BCL files generated by Illumina sequencing systems to standard FASTQ
    fastp		Trim and removes adapters from fastq files
    fastqc		QCs the fastq files and outputs a html file
    kraken2		Performs taxonomic classification of reads and contigs
    krona		Generates interactive pie plots from kraken2 reports
    bowtie2		Reads mapping tool
    samtools		Read aligment analysis tool
    usearch		implements sequence search and clustering algorithms: including USEARCH, UCLUST, UPARSE, UCHIME, UNOISE and SINTAX
