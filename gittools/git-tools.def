Bootstrap: docker
From: ubuntu:latest

%post
    # Update and install Git, Git LFS, and useful tools
    apt update && apt install -y pipx git git-lfs curl python3 python3-pip
    
    # Install git-filter-repo via pip
    pipx install git-filter-repo

    # Configure Git LFS
    git lfs install

    export PATH=/root/.local/bin:$PATH
    echo 'export PATH=/root/.local/bin:$PATH' >> /root/.bashrc

%environment
    export PATH=/usr/bin:/root/.local/bin:$PATH
    export HOME=/root

%test
    # Verify installation
    git --version
    git-lfs --version
    git filter-repo --help

%runscript
    echo "Git Utilities Container"
    git --version
    exec $*
