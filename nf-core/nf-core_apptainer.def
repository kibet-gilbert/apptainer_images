Bootstrap: docker
From: ubuntu:22.04

%labels
    Author Gilbert Kibet
    Version nf-core_2.14.0
    Description Container for running nf-core pipelines using Nextflow with Apptainer

%environment
    export PATH="/opt/nextflow:$PATH"
    export NXF_HOME="/opt/.nextflow"
    export NXF_SINGULARITY_CACHEDIR="/opt/containers"
    export PYTHONPATH="$HOME/.local/lib/python3.10/site-packages:$PYTHONPATH"

%post
    apt-get update && apt-get install -y \
        openjdk-11-jdk \
        curl \
        unzip \
        python3 \
        python3-pip \
        git \
        wget \
        rsync \
        locales \
        ca-certificates \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

    # Set locale
    locale-gen en_US.UTF-8
    update-locale LANG=en_US.UTF-8

    # Install Nextflow
    mkdir -p /opt/nextflow && \
    curl -fsSL https://get.nextflow.io | bash && \
    mv nextflow /opt/nextflow/ && \
    chmod +x /opt/nextflow/nextflow

    # Install nf-core tools
    pip install --upgrade pip
    pip install nf-core

    # Create default container cache dir
    mkdir -p /opt/.nextflow
    mkdir -p /opt/containers

%runscript
    echo "This container includes Nextflow + nf-core tools"
    echo "Try running: nextflow run nf-core/ampliseq --help"
    exec /bin/bash "$@"

